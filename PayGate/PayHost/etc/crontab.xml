<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job instance="PayGate\PayHost\Cron\CronQuery" method="execute" name="paygate_payhost_query">
            <schedule>*/10 * * * *</schedule>
        </job>
        <job instance="PayGate\PayHost\Cron\CleanupCache" method="execute" name="paygate_payhost_cleanup_cache">
            <schedule>0 2 * * *</schedule>
        </job>
    </group>
</config>
